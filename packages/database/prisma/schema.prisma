generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  USER
}

enum AccountStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DELETED
}

enum RegistrationMode {
  INVITE_ONLY
  SELF_REGISTER
  SELF_REGISTER_AUTO
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  password      String
  role          Role          @default(USER)
  accountStatus AccountStatus @default(PENDING)

  firstName            String?
  lastName             String?
  displayName          String?
  avatarUrl            String?
  phone                String?
  verificationCode     String?
  verificationExpires  DateTime?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  lastActiveAt         DateTime?

  city        String?
  country     String?
  language    String?
  dateOfBirth DateTime?

  shippingName       String?
  shippingPhone      String?
  shippingLine1      String?
  shippingLine2      String?
  shippingCity       String?
  shippingPostalCode String?
  shippingCountry    String?

  googleId           String?   @unique
  googleRefreshToken String?

  activeDeviceId String?

  invitedById String?
  invitedBy   User?   @relation("UserInvites", fields: [invitedById], references: [id])
  invitees    User[]  @relation("UserInvites")
  auditLogs     AuditLog[]
  notifications Notification[]

  albumPurchases      AlbumPurchase[]
  orders              Order[]
  paymentTransactions PaymentTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
  @@index([googleId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  meta      Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, read])
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- MUSIC CATALOG ---

enum AlbumStatus {
  DRAFT
  LIVE
  ARCHIVED
}

model Album {
  id            String      @id @default(cuid())
  title         String
  slug          String      @unique
  description   String?
  coverImageUrl String?
  status        AlbumStatus @default(DRAFT)
  priceCents    Int
  currency      String      @default("ZAR")
  releaseDate   DateTime?

  tracks    Track[]
  purchases AlbumPurchase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model Track {
  id       String  @id @default(cuid())
  title    String
  order    Int
  duration Int     @default(0)
  audioUrl String
  isFree   Boolean @default(false)

  albumId String
  album   Album  @relation(fields: [albumId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([albumId, order])
  @@index([albumId, isFree])
}

model AlbumPurchase {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  albumId     String
  album       Album    @relation(fields: [albumId], references: [id])
  priceCents  Int
  currency    String
  purchasedAt DateTime @default(now())

  @@unique([userId, albumId])
  @@index([userId])
}

// --- MERCH ---

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  CANCELLED
}

enum ProductCategory {
  APPAREL
  ACCESSORIES
  BOOKS
}

model Product {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  description String?
  images      String[]
  category    ProductCategory @default(APPAREL)
  isActive    Boolean         @default(true)

  variants ProductVariant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model ProductVariant {
  id         String  @id @default(cuid())
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  label      String
  sku        String  @unique
  priceCents Int
  stock      Int     @default(0)

  orderItems OrderItem[]

  @@index([productId])
}

model Order {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  status     OrderStatus @default(PENDING)
  totalCents Int
  currency   String      @default("ZAR")

  shippingName       String
  shippingPhone      String
  shippingLine1      String
  shippingLine2      String?
  shippingCity       String
  shippingPostalCode String
  shippingCountry    String @default("ZA")

  items OrderItem[]

  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id               String         @id @default(cuid())
  orderId          String
  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  quantity         Int
  unitPriceCents   Int
}

// --- PAYMENTS ---

enum PaymentPurpose {
  ALBUM_PURCHASE
  MERCH_ORDER
}

enum PaymentStatus {
  PENDING
  COMPLETE
  FAILED
  CANCELLED
}

model PaymentTransaction {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id])
  purpose     PaymentPurpose
  referenceId String
  pfPaymentId String?        @unique
  mPaymentId  String
  amountCents Int
  currency    String         @default("ZAR")
  status      PaymentStatus  @default(PENDING)
  rawPayload  Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([purpose])
  @@index([status])
}

// --- BOOKINGS ---

enum BookingStatus {
  NEW
  CONTACTED
  CONFIRMED
  DECLINED
  ARCHIVED
}

model BookingInquiry {
  id           String        @id @default(cuid())
  name         String
  email        String
  phone        String?
  eventDetails String
  message      String?
  status       BookingStatus @default(NEW)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// --- CONTENT PAGES ---

model GalleryImage {
  id        String   @id @default(cuid())
  url       String
  caption   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

enum EventCategory {
  GENERAL
  HARINAM
}

model Event {
  id          String        @id @default(cuid())
  title       String
  description String?
  venue       String
  city        String?
  date        DateTime
  ticketUrl   String?
  imageUrl    String?
  category    EventCategory @default(GENERAL)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([date])
  @@index([category])
}
